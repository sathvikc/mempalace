    "dialogue_patterns": [
      "^>\\s*{name}[:\\s]",
      "^{name}:\\s",
      "^\\[{name}\\]",
      "\"{name}\\s+сказал"
    ],
    "direct_address_pattern": "\\bпривет\\s+{name}\\b|\\bспасибо\\s+{name}\\b|\\bздравствуй(те)?\\s+{name}\\b|\\bуважаемый\\s+{name}\\b|\\bуважаемая\\s+{name}\\b|\\bдорогой\\s+{name}\\b|\\bдорогая\\s+{name}\\b",
    "project_verb_patterns": [
